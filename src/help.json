{
  "title": "Wave Edit",
  "children": [
    {
      "title": "Overview",
      "lines": [
        "Edit WAV files on",
        "your Move. Trim,",
        "adjust gain, mute,",
        "copy/paste, normalize,",
        "and BPM-grid slicing.",
        "",
        "Waveform display with",
        "zoom and minimap.",
        "Undo support for all",
        "destructive edits."
      ]
    },
    {
      "title": "Navigation",
      "lines": [
        "Jog (zoomed): scroll",
        "  through waveform",
        "  (clamped to file)",
        "Shift+Jog: fine scroll",
        "",
        "Jog click: edit menu",
        "  Copy / Cut /",
        "  Truncate / Normalize Sel",
        "  / BPM Step / Mute",
        "Shift+Jog click:",
        "  Paste (insert) /",
        "  Paste (overwrite) /",
        "  Export",
        "",
        "E1 (Knob 1): move",
        "  start marker",
        "E2 (Knob 2): move",
        "  end marker",
        "E3 (Knob 3): zoom",
        "E4 (Knob 4): vertical",
        "  scale (1x-32x)",
        "",
        "Left/Right: nudge",
        "  selection by one",
        "  coarse step",
        "Shift+L/R: jump by",
        "  one selection length"
      ]
    },
    {
      "title": "Editing",
      "lines": [
        "E5 (Knob 5): gain",
        "  Shift: normalize",
        "",
        "Mute: zero out selection",
        "Step 15: set start",
        "  marker at playback",
        "  position",
        "Step 16: set end",
        "  marker at playback",
        "  position",
        "Copy: copy selection",
        "Shift+Copy: paste",
        "  (insert at cursor)",
        "Remove: cut selection",
        "  (copy + remove)",
        "",
        "Undo: undo last edit",
        "All edits reversible."
      ]
    },
    {
      "title": "Playback",
      "lines": [
        "Any pad: hold to",
        "  audition selection",
        "  release to stop",
        "",
        "Shift+Pad: preview",
        "  near end marker",
        "",
        "E7 touch+twist: toggle",
        "  loop mode on/off",
        "E8 touch+twist: snap",
        "  to zero crossing",
        "",
        "Header shows:",
        " * = unsaved changes",
        " L = loop enabled"
      ]
    },
    {
      "title": "Loop View",
      "lines": [
        "Loop: enter loop view",
        "  (seam editor for",
        "  seamless loops)",
        "",
        "E1: adjust loop point",
        "E2: adjust loop end",
        "E3: zoom seam view",
        "E4: vertical scale",
        "Jog click: toggle",
        "  loop point / end",
        "",
        "E7 touch+twist: toggle",
        "  loop on/off",
        "E8 touch+twist: snap",
        "  to zero crossing",
        "Loop: return to edit"
      ]
    },
    {
      "title": "Slice Mode",
      "lines": [
        "Step 3: enter slice mode",
        "Step 1: return to edit",
        "",
        "Jog: cycle mode",
        "  Even / Auto /",
        "  Lazy / BPM",
        "",
        "E1: adjust slice start",
        "E2: adjust slice end",
        "E3: zoom",
        "E4: vertical scale",
        "E5: Count (Even) /",
        "  Threshold (Auto) /",
        "  Chop-Play (Lazy) /",
        "  BPM value (BPM)",
        "E6: Division (BPM)",
        "E8: select slice",
        "",
        "Modes: Even, Auto",
        "  (transient detect),",
        "  Lazy (real-time",
        "  chop), BPM (grid)",
        "",
        "Pads: select + play",
        "  slice (hold to",
        "  audition)",
        "Left/Right: prev/next",
        "  slice",
        "Shift+L/R: move slice",
        "  left/right (swap)",
        "Down: split slice",
        "Up: merge with prev",
        "",
        "Step 16: shuffle all",
        "  slices randomly",
        "Copy: copy slice",
        "Shift+Copy: paste",
        "  insert before slice",
        "Remove: cut slice",
        "",
        "Sample: save slices /",
        "  Drum Preset /",
        "  REX Loop"
      ]
    },
    {
      "title": "Lazy Chop",
      "lines": [
        "In Slice mode, select",
        "Lazy mode. Sub-modes:",
        "",
        "Chop: press Pad 1 to",
        "  start playback.",
        "  Press again to add",
        "  chop points in",
        "  real time. Playback",
        "  ends at file end",
        "  or press Capture.",
        "",
        "Play: audition slices",
        "  with pads after",
        "  chopping is done.",
        "",
        "E5 toggles",
        "  Chop / Play sub-mode."
      ]
    },
    {
      "title": "BPM Mode",
      "lines": [
        "BPM Step (Trim):",
        "  Jog click > BPM Step",
        "  Jog: scroll view",
        "  Jog click: toggle",
        "    start / end",
        "  E1: start marker",
        "    (in beat steps)",
        "  E2: end marker",
        "    (in beat steps)",
        "  E3: zoom",
        "  E5: set BPM",
        "    (Shift: fine ±0.1)",
        "    snaps end marker",
        "    to beat grid",
        "  E6: set division",
        "  Copy: copy selection",
        "  Shift+Copy: paste",
        "    (insert at cursor)",
        "  Down: BPM from",
        "    filename",
        "  Up: estimate BPM",
        "    from selection",
        "    (assumes 1 bar 4/4)",
        "  Step 15: set start",
        "    marker at playback",
        "  Step 16: set end",
        "    marker at playback",
        "  L/R: move marker",
        "    by one division",
        "  Shift+L/R: move",
        "    selection by one",
        "    division",
        "  Shift+Loop: toggle",
        "    loop on/off",
        "  Back: return to edit",
        "",
        "BPM Slice:",
        "  Jog: select mode",
        "  E5: BPM value",
        "  E6: division",
        "  E8: select slice",
        "  Max 32 slices"
      ]
    },
    {
      "title": "Recording",
      "lines": [
        "Open File browser:",
        "  select New Recording",
        "  to create a new file",
        "",
        "Records Move's audio",
        "  output (resample).",
        "",
        "REC LED flashes when",
        "  armed. Press REC to",
        "  start recording.",
        "Press REC again to",
        "  stop. File loads",
        "  into editor.",
        "",
        "Back: cancel and",
        "  return to browser"
      ]
    },
    {
      "title": "Saving",
      "lines": [
        "Sample: open save menu",
        "  with editable filename",
        "  and save action",
        "",
        "Shift+Capture: export",
        "  selection to a",
        "  new file",
        "",
        "In Slice mode, Sample",
        "  offers: Slices,",
        "  Drum Preset, or",
        "  REX Loop (if Rex",
        "  module installed)",
        "",
        "Saved files go to",
        "  UserLibrary/Recordings",
        "",
        "Back: hide (keeps DSP",
        "  alive). Close Session",
        "  from menu to fully",
        "  exit."
      ]
    }
  ]
}
